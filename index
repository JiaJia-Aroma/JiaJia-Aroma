            padding: 6px 16px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            background: var(--secondary-gold);
            color: white;
        }

        .phone-float {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: var(--primary-red);
            color: white;
            width: 64px;
            height: 64px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 6px 24px rgba(196, 30, 58, 0.4);
            cursor: pointer;
            z-index: 1000;
            transition: all 0.3s ease;
            animation: pulse 2s infinite;
        }

        .phone-float:hover {
            transform: scale(1.1);
            box-shadow: 0 8px 32px rgba(196, 30, 58, 0.5);
        }

        @keyframes pulse {
            0%, 100% {
                box-shadow: 0 6px 24px rgba(196, 30, 58, 0.4);
            }
            50% {
                box-shadow: 0 6px 24px rgba(196, 30, 58, 0.4), 0 0 0 15px rgba(196, 30, 58, 0.1);
            }
        }

        .nav-link {
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 8px;
            transition: all 0.3s ease;
            font-weight: 500;
